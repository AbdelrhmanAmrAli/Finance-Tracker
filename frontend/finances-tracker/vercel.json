{
  "version": 2,
  "builds": [
    {
      "src": "package.json",  // Key change: Use package.json instead of vite.config.js
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"  // Must match Vite's outDir
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "status": 200
    }
  ]
}